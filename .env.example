# Runtime
NODE_ENV=development

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
NEXT_PUBLIC_NETLIFY_SITE_URL=
WEB_PORT=3000

# API
API_PORT=3001
API_PREFIX=api
CORS_ORIGIN=*

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/analyzer_video
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=analyzer_video
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Queue resiliency
QUEUE_JOB_ATTEMPTS=3
QUEUE_JOB_BACKOFF_MS=1000

# YouTube Data API
YOUTUBE_API_KEY=replace_me
YOUTUBE_API_BASE_URL=https://www.googleapis.com/youtube/v3
YOUTUBE_MAX_RETRIES=3
YOUTUBE_TIMEOUT_MS=8000

# OpenAI
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT_MS=15000
